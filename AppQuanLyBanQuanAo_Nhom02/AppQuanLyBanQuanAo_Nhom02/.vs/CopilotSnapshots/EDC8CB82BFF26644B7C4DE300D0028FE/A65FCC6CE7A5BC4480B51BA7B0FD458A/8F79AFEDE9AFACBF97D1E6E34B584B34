<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.SaoLuuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#8E44AD">
            <StackPanel Margin="20">
                <TextBlock Text="SAO LƯU VÀ PHỤC HỒI DỮ LIỆU" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Quản lý các bản sao lưu và phục hồi dữ liệu hệ thống" FontSize="12" Foreground="#E8DAEF" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Settings Bar -->
        <Border Grid.Row="1" Background="White">
            <StackPanel Margin="20">
                <TextBlock Text="📁 Thư mục sao lưu:" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding DuongDanBackup, Mode=OneWay}"
                             Padding="10,8"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             FontSize="11"
                             Background="#ECF0F1"
                             IsReadOnly="True"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1"
                            Command="{Binding ChonThuMucCommand}"
                            Padding="15,8"
                            Background="#8E44AD"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="11"
                            Cursor="Hand"
                            Content="📂 Chọn thư mục">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#8E44AD"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7D3C98"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Danh sách Backup -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#BDC3C7" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="DANH SÁCH CÁC BẢN SAO LƯU" 
                               Background="#8E44AD" 
                               Foreground="White" 
                               Padding="15,10" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <ListBox x:Name="BackupListBox"
                             ItemsSource="{Binding DanhSachBackup}"
                             Background="White"
                             Foreground="#2C3E50"
                             BorderThickness="0"
                             Margin="0"
                             Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                        BorderBrush="#ECF0F1" 
                                        BorderThickness="0,0,0,1"
                                        Padding="15,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding}" 
                                                   FontWeight="Bold" 
                                                   FontSize="12"
                                                   Foreground="#2C3E50"/>
                                        <TextBlock Text="Ngày tạo: 2024-01-15 14:30:45" 
                                                   FontSize="10"
                                                   Foreground="#7F8C8D"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Control Panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="ĐIỀU KHIỂN" 
                               Background="#8E44AD" 
                               Foreground="White" 
                               Padding="10,8" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <ScrollViewer DockPanel.Dock="Top">
                        <StackPanel Margin="15">
                            <!-- Thông tin -->
                            <TextBlock Text="ℹ THÔNG TIN" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,10"/>

                            <Border Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" Padding="12" Margin="0,0,0,15">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Số file backup:" FontSize="11" Foreground="#2C3E50" Width="130"/>
                                        <TextBlock Text="{Binding DanhSachBackup.Count, StringFormat='0 file'}" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"
                                                   Foreground="#8E44AD"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Dung lượng:" FontSize="11" Foreground="#2C3E50" Width="130"/>
                                        <TextBlock Text="{Binding DungLuongBackup, StringFormat='{0:N0} Bytes'}" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"
                                                   Foreground="#8E44AD"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Lần cuối:" FontSize="11" Foreground="#2C3E50" Width="130"/>
                                        <TextBlock Text="{Binding ThoiGianCuoiSaoLuu, StringFormat='dd/MM/yyyy HH:mm'}" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"
                                                   Foreground="#8E44AD"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Progress Bar -->
                            <TextBlock Text="Tiến độ:" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <ProgressBar Value="{Binding TienDoSaoLuu}" 
                                         Height="20" 
                                         Background="#ECF0F1"
                                         Foreground="#8E44AD"
                                         Margin="0,0,0,15">
                                <ProgressBar.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.2"/>
                                </ProgressBar.Effect>
                            </ProgressBar>

                            <TextBlock Text="{Binding TienDoSaoLuu, StringFormat='{0}%'}" 
                                       TextAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#8E44AD"
                                       Margin="0,0,0,15"/>

                            <!-- Separator -->
                            <Separator Margin="0,10,0,15"/>

                            <!-- Action Buttons -->
                            <TextBlock Text="🔧 HÀNH ĐỘNG" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,10"/>

                            <Button Command="{Binding SaoLuuNgayCommand}"
                                    Padding="12,12"
                                    Background="#27AE60"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Content="💾 Sao lưu ngay"
                                    Margin="0,0,0,8">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#27AE60"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#229954"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Command="{Binding PhucHoiCommand}"
                                    Padding="12,12"
                                    Background="#3498DB"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Content="♻ Phục hồi dữ liệu"
                                    Margin="0,0,0,8">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2980B9"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Command="{Binding XoaBackupCommand}"
                                    Padding="12,12"
                                    Background="#E74C3C"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Content="✕ Xóa file">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C0392B"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ThongBao}"
                           Foreground="#2C3E50"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <ProgressBar Grid.Column="1"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             IsIndeterminate="True"
                             Height="4"
                             Width="100"
                             Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
