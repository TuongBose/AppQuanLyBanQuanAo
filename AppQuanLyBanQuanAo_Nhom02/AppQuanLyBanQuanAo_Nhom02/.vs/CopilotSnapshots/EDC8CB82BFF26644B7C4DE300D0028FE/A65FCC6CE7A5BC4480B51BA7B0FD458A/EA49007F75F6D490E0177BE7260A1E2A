<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.KhachHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1200">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#E74C3C">
            <StackPanel Margin="20">
                <TextBlock Text="QUẢN LÝ KHÁCH HÀNG" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Quản lý thông tin khách hàng và điểm tích lũy" FontSize="12" Foreground="#FADBD8" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Search and Buttons Bar -->
        <Border Grid.Row="1" Background="White">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12" Foreground="#34495E"/>
                    <TextBox x:Name="TimKiemTextBox" 
                             Text="{Binding TimKiem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="250" 
                             Padding="10,8" 
                             FontSize="12"
                             Background="White"
                             Foreground="#2C3E50"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1">
                    </TextBox>
                </StackPanel>

                <Button Grid.Column="1" 
                        Command="{Binding TimKiemCommand}"
                        Padding="15,8" 
                        Margin="10,0,5,0"
                        Background="#E74C3C" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="🔍 Tìm kiếm">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E74C3C"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C0392B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" 
                        Command="{Binding LamMoiCommand}"
                        Padding="15,8" 
                        Margin="5,0"
                        Background="#95A5A6" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="🔄 Làm mới">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#95A5A6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7F8C8D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" 
                        Command="{Binding TaiDuLieuCommand}"
                        Padding="15,8" 
                        Margin="5,0,0,0"
                        Background="#27AE60" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="⬇ Tải dữ liệu">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#27AE60"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#229954"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="350" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#BDC3C7" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="DANH SÁCH KHÁCH HÀNG" 
                               Background="#E74C3C" 
                               Foreground="White" 
                               Padding="15,10" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <DataGrid x:Name="KhachHangGrid"
                              ItemsSource="{Binding DanhSachKhachHang}"
                              SelectedItem="{Binding KhachHangDangChon}"
                              AutoGenerateColumns="False"
                              Background="White"
                              Foreground="#2C3E50"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Margin="0"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKH}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SDT}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Điểm tích lũy" Binding="{Binding DiemTichLuy}" Width="100" IsReadOnly="True"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="THÔNG TIN KHÁCH HÀNG" 
                               Background="#E74C3C" 
                               Foreground="White" 
                               Padding="10,8" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <ScrollViewer DockPanel.Dock="Top">
                        <StackPanel Margin="15">
                            <!-- Tên Khách Hàng -->
                            <TextBlock Text="Tên khách hàng *" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="TenKHTextBox"
                                     Text="{Binding KhachHangMoi.TenKH, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,12"/>

                            <!-- Số Điện Thoại -->
                            <TextBlock Text="Số điện thoại" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="SDTTextBox"
                                     Text="{Binding KhachHangMoi.SDT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,12"/>

                            <!-- Điểm Tích Lũy -->
                            <TextBlock Text="Điểm tích lũy" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="DiemTextBox"
                                     Text="{Binding KhachHangMoi.DiemTichLuy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,20"/>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                                <Button Command="{Binding ThemKhachHangCommand}"
                                        Padding="10,10"
                                        Background="#27AE60"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✓ Thêm khách hàng"
                                        Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#27AE60"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#229954"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding SuaKhachHangCommand}"
                                        Padding="10,10"
                                        Background="#F39C12"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✎ Cập nhật"
                                        Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#F39C12"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E67E22"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding XoaKhachHangCommand}"
                                        Padding="10,10"
                                        Background="#E74C3C"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✕ Xóa">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#E74C3C"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C0392B"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ThongBao}"
                           Foreground="#2C3E50"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <ProgressBar Grid.Column="1"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             IsIndeterminate="True"
                             Height="4"
                             Width="100"
                             Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
