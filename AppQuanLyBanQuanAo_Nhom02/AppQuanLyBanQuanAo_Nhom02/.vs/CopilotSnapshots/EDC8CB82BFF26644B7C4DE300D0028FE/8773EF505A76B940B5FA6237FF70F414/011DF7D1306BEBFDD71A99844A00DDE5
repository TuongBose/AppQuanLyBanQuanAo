<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.NhanVienView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1200">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50">
            <StackPanel Margin="20">
                <TextBlock Text="QUẢN LÝ NHÂN VIÊN" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Quản lý thông tin nhân viên bán hàng" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Search and Buttons Bar -->
        <Border Grid.Row="1" Background="White">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12" Foreground="#34495E"/>
                    <TextBox x:Name="TimKiemTextBox" 
                             Text="{Binding TimKiem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="250" 
                             Padding="10,8" 
                             FontSize="12"
                             Background="White"
                             Foreground="#2C3E50"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1">
                    </TextBox>
                </StackPanel>

                <Button Grid.Column="1" 
                        Command="{Binding TimKiemCommand}"
                        Padding="15,8" 
                        Margin="10,0,5,0"
                        Background="#3498DB" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="🔍 Tìm kiếm">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3498DB"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" 
                        Command="{Binding LamMoiCommand}"
                        Padding="15,8" 
                        Margin="5,0"
                        Background="#95A5A6" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="🔄 Làm mới">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#95A5A6"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7F8C8D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" 
                        Command="{Binding TaiDuLieuCommand}"
                        Padding="15,8" 
                        Margin="5,0,0,0"
                        Background="#27AE60" 
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="12"
                        Cursor="Hand"
                        Content="⬇ Tải dữ liệu">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#27AE60"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#229954"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="350" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid - Danh sách nhân viên -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#BDC3C7" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="DANH SÁCH NHÂN VIÊN" 
                               Background="#34495E" 
                               Foreground="White" 
                               Padding="15,10" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <DataGrid x:Name="NhanVienGrid"
                              ItemsSource="{Binding DanhSachNhanVien}"
                              SelectedItem="{Binding NhanVienDangChon}"
                              AutoGenerateColumns="False"
                              Background="White"
                              Foreground="#2C3E50"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Margin="0"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã NV" Binding="{Binding MaNV}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên nhân viên" Binding="{Binding TenNV}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tài khoản" Binding="{Binding Username}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Điện thoại" Binding="{Binding SDT}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Chức vụ" 
                                                Binding="{Binding Role}" 
                                                Width="80" 
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="Trạng thái" 
                                                Binding="{Binding TrangThai}" 
                                                Width="80" 
                                                IsReadOnly="True"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3498DB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ECF0F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Form - Thêm/Sửa nhân viên -->
            <Border Grid.Column="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="THÔNG TIN NHÂN VIÊN" 
                               Background="#34495E" 
                               Foreground="White" 
                               Padding="10,8" 
                               FontWeight="Bold"
                               FontSize="13"/>
                    <ScrollViewer DockPanel.Dock="Top">
                        <StackPanel Margin="15">
                            <!-- Tên Nhân Viên -->
                            <TextBlock Text="Tên nhân viên *" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="TenNVTextBox"
                                     Text="{Binding NhanVienMoi.TenNV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,12"/>

                            <!-- Tài khoản -->
                            <TextBlock Text="Tài khoản *" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="UsernameTextBox"
                                     Text="{Binding NhanVienMoi.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,12"/>

                            <!-- Mật khẩu -->
                            <TextBlock Text="Mật khẩu" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="PasswordBox"
                                         Padding="10,8"
                                         BorderBrush="#BDC3C7"
                                         BorderThickness="1"
                                         FontSize="11"
                                         Margin="0,0,0,12"/>

                            <!-- Điện thoại -->
                            <TextBlock Text="Điện thoại" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <TextBox x:Name="PhoneTextBox"
                                     Text="{Binding NhanVienMoi.SDT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     FontSize="11"
                                     Margin="0,0,0,12"/>

                            <!-- Chức vụ -->
                            <TextBlock Text="Chức vụ" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <ComboBox x:Name="RoleComboBox"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding NhanVienMoi.Role, Mode=TwoWay}"
                                      Padding="10,8"
                                      BorderBrush="#BDC3C7"
                                      BorderThickness="1"
                                      FontSize="11"
                                      Margin="0,0,0,12">
                                <ComboBoxItem Tag="0" Content="Nhân viên"/>
                                <ComboBoxItem Tag="1" Content="Quản lý"/>
                            </ComboBox>

                            <!-- Trạng thái -->
                            <TextBlock Text="Trạng thái" FontWeight="Bold" FontSize="11" Foreground="#2C3E50" Margin="0,0,0,5"/>
                            <ComboBox x:Name="StatusComboBox"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding NhanVienMoi.TrangThai, Mode=TwoWay}"
                                      Padding="10,8"
                                      BorderBrush="#BDC3C7"
                                      BorderThickness="1"
                                      FontSize="11"
                                      Margin="0,0,0,20">
                                <ComboBoxItem Tag="1" Content="Đang làm việc"/>
                                <ComboBoxItem Tag="0" Content="Đã nghỉ"/>
                            </ComboBox>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                                <Button Command="{Binding ThemNhanVienCommand}"
                                        Padding="10,10"
                                        Background="#27AE60"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✓ Thêm nhân viên"
                                        Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#27AE60"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#229954"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding SuaNhanVienCommand}"
                                        Padding="10,10"
                                        Background="#F39C12"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✎ Cập nhật"
                                        Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#F39C12"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E67E22"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding XoaNhanVienCommand}"
                                        Padding="10,10"
                                        Background="#E74C3C"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Content="✕ Xóa">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#E74C3C"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C0392B"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ThongBao}"
                           Foreground="#2C3E50"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <ProgressBar Grid.Column="1"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             IsIndeterminate="True"
                             Height="4"
                             Width="100"
                             Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
