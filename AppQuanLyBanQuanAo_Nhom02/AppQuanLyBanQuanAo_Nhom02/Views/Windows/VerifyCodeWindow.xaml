<Window x:Class="AppQuanLyBanQuanAo_Nhom02.Views.Windows.VerifyCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.Windows"
        xmlns:vm="clr-namespace:AppQuanLyBanQuanAo_Nhom02.ViewModels"
        mc:Ignorable="d"
        Title="Xác thực mã đăng ký" Height="300" Width="400" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" 
        Name="VerifyWin">
    
    <Window.DataContext>
        <vm:VerifyCodeViewModel/>
    </Window.DataContext>

    <StackPanel Margin="30,25,30,20">
        <TextBlock Text="XÁC THỰC MÃ BẢO MẬT" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Text="Vui lòng nhập mã 6 số do Quản lý cấp:" Foreground="#7F8C8D" Margin="0,0,0,5"/>
        <TextBox Text="{Binding CodeInput, UpdateSourceTrigger=PropertyChanged}" 
                 FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Center" 
                 Padding="8" BorderBrush="#3498DB" BorderThickness="2" Margin="0,0,0,5"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,15" Height="16"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Hủy bỏ" Command="{Binding CancelCommand}" CommandParameter="{Binding ElementName=VerifyWin}" 
                    Background="#ECF0F1" Foreground="#7F8C8D" FontWeight="Bold" Height="35" BorderThickness="0" Cursor="Hand"/>

            <Button Grid.Column="2" Content="Xác nhận" Command="{Binding VerifyCommand}" CommandParameter="{Binding ElementName=VerifyWin}" 
                    Background="#2ECC71" Foreground="White" FontWeight="Bold" Height="35" BorderThickness="0" Cursor="Hand" IsDefault="True"/>
        </Grid>
    </StackPanel>
</Window>
