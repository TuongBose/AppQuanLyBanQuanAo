<Window x:Class="AppQuanLyBanQuanAo_Nhom02.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.Windows"
        xmlns:vm="clr-namespace:AppQuanLyBanQuanAo_Nhom02.ViewModels"
        mc:Ignorable="d"
        Title="Xác nhận đổi mật khẩu" 
        Height="420" Width="380" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Name="ChangePassWin">

    <Window.DataContext>
        <vm:ChangePasswordViewModel/>
    </Window.DataContext>

    <StackPanel Margin="30,20,30,20">
        <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Mật khẩu hiện tại:" FontWeight="SemiBold"/>
        <TextBox Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}" 
                 BorderBrush="{Binding OldPasswordBorder}" BorderThickness="1" Margin="0,5,0,0" Padding="5"
                 KeyDown="FocusNext_KeyDown"/>
        <TextBlock Text="{Binding OldPasswordError}" Foreground="Red" FontSize="11" Margin="0,2,0,10"/>

        <TextBlock Text="Mật khẩu mới:" FontWeight="SemiBold"/>
        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                 BorderBrush="{Binding NewPasswordBorder}" BorderThickness="1" Margin="0,5,0,0" Padding="5"
                 KeyDown="FocusNext_KeyDown"/>
        <TextBlock Text="{Binding NewPasswordError}" Foreground="Red" FontSize="11" Margin="0,2,0,10" TextWrapping="Wrap"/>

        <TextBlock Text="Nhập lại mật khẩu mới:" FontWeight="SemiBold"/>
        <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" 
                 BorderBrush="{Binding ConfirmPasswordBorder}" BorderThickness="1" Margin="0,5,0,0" Padding="5"/>
        <TextBlock Text="{Binding ConfirmPasswordError}" Foreground="Red" FontSize="11" Margin="0,2,0,15"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Hủy bỏ" Command="{Binding CancelCommand}" CommandParameter="{Binding ElementName=ChangePassWin}" Height="35" Background="#BDC3C7" FontWeight="Bold" Cursor="Hand"/>
            <Button Grid.Column="2" Content="Lưu thay đổi" Command="{Binding SavePasswordCommand}" CommandParameter="{Binding ElementName=ChangePassWin}" Height="35" Background="#2980B9" Foreground="White" FontWeight="Bold" IsDefault="True" Cursor="Hand"/>
        </Grid>
    </StackPanel>
</Window>
