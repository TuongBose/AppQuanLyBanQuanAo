<Window x:Class="AppQuanLyBanQuanAo_Nhom02.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.Windows"
        xmlns:vm="clr-namespace:AppQuanLyBanQuanAo_Nhom02.ViewModels"
        mc:Ignorable="d"
        Title="Đăng nhập hệ thống" Height="400" Width="400" WindowStartupLocation="CenterScreen"
        Name="LoginWin">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="ĐĂNG NHẬP" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Tài khoản:" />
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                 KeyDown="FocusNext_KeyDown" 
                 Margin="0,5,0,15" 
                 Padding="5"/>

        <TextBlock Text="Mật khẩu:" />
        <Grid Margin="0,5,0,15">
            <!-- 1. Trạng thái ẨN (Mặc định) -->
            <PasswordBox x:Name="txtPassword" 
                         Padding="5,5,35,5" 
                         PasswordChanged="txtPassword_PasswordChanged"/>

            <!-- 2. Trạng thái HIỆN (Bị ẩn đi lúc mới mở) -->
            <TextBox x:Name="txtVisiblePassword" 
                     Padding="5,5,35,5" 
                     Visibility="Collapsed" 
                     TextChanged="txtVisiblePassword_TextChanged"/>

            <!-- 3. Nút Con Mắt (Nằm đè lên góc phải của ô nhập) -->
            <ToggleButton x:Name="btnShowPassword"
                          HorizontalAlignment="Right"
                          Width="30" Height="30"
                          Margin="0,0,2,0"
                          Background="Transparent" BorderThickness="0"
                          Cursor="Hand"
                          Click="btnShowPassword_Click">
                <TextBlock Text="👁" FontSize="16" Margin="0,2,0,0"/>
            </ToggleButton>
        </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Button Content="Đăng Nhập" 
                IsDefault="True"
                Command="{Binding LoginCommand}" 
                CommandParameter="{Binding ElementName=txtPassword}" 
                Height="35" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>

        <Button Content="Bạn là nhân viên mới? Đăng ký tại đây" Command="{Binding GoToRegisterCommand}" 
        CommandParameter="{Binding ElementName=LoginWin}"
        Background="Transparent" BorderThickness="0" Foreground="DodgerBlue" Cursor="Hand" Margin="0,10,0,0"/>
    </StackPanel>
    
</Window>
