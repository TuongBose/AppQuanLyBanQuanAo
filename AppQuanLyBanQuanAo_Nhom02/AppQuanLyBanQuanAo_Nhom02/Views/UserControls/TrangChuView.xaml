<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.TrangChuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000" 
             IsVisibleChanged="UserControl_IsVisibleChanged">
    <Grid Margin="0">

        <Grid Visibility="{Binding AdminVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="4" Height="110" Margin="0,0,0,20">

                <Border BorderBrush="#27AE60" BorderThickness="1.5" Background="#EAFDF1" CornerRadius="6" Margin="0,0,15,0" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="💰" Foreground="#27AE60" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DOANH THU HÔM NAY" Foreground="#27AE60" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TongDoanhThu}" Foreground="#1A252F" FontWeight="ExtraBold" FontSize="26"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#2980B9" BorderThickness="1.5" Background="#EBF5FB" CornerRadius="6" Margin="0,0,15,0" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="📄" Foreground="#2980B9" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SỐ HÓA ĐƠN HÔM NAY" Foreground="#2980B9" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SoHoaDonHomNay}" Foreground="#1A252F" FontWeight="ExtraBold" FontSize="26"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#F39C12" BorderThickness="1.5" Background="#FEF9E7" CornerRadius="6" Margin="0,0,15,0" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="⭐" Foreground="#F39C12" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="TỔNG KHÁCH HÀNG" Foreground="#F39C12" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TongKhachHang}" Foreground="#1A252F" FontWeight="ExtraBold" FontSize="26"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#8E44AD" BorderThickness="1.5" Background="#F4ECF7" CornerRadius="6" Margin="0,0,0,0" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="👤" Foreground="#8E44AD" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="TỔNG NHÂN VIÊN" Foreground="#8E44AD" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TongNhanVien}" Foreground="#1A252F" FontWeight="ExtraBold" FontSize="26"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#D3D3D3" Opacity="0.4"/>
                </Border.Effect>

                <Border CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="CẢNH BÁO: SẢN PHẨM SẮP HẾT HÀNG (TỒN KHO &lt;= 5)" 
                                   Foreground="#E74C3C" FontWeight="Bold" FontSize="16" Margin="20,20,20,15"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SanPhamSapHetHang}" AutoGenerateColumns="False" IsReadOnly="True" 
                                  Background="White" RowBackground="White" AlternatingRowBackground="#F8F9FA" 
                                  RowHeight="45" HeadersVisibility="Column" BorderThickness="0" 
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAECEE">

                            <DataGrid.Resources>
                                <Style x:Key="CenterText" TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>

                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                            </DataGrid.Resources>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#34495E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Height" Value="45"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="100" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSP}" Width="*" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Màu sắc" Binding="{Binding MauSac}" Width="120" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Giá bán" Binding="{Binding GiaBan, StringFormat={}{0:N0}}" Width="130" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Tồn" Binding="{Binding SoLuong}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CenterText}">
                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Border>
        </Grid>

        <Grid Visibility="{Binding EmployeeVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#D3D3D3" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="{Binding EmployeeName, StringFormat='Xin chào, {0}!'}" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Chúc bạn một ca làm việc hiệu quả và tràn đầy năng lượng!" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CurrentTime}" FontSize="28" FontWeight="ExtraBold" Foreground="#3498DB" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding LapHoaDonMoiCommand}" Background="#27AE60" Foreground="White" Height="80" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="40" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="LẬP HÓA ĐƠN MỚI" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Command="{Binding TraCuuKhachHangCommand}" Background="#F39C12" Foreground="White" Height="80" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="30" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="TRA CỨU KHÁCH HÀNG" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#D3D3D3" Opacity="0.4"/>
                </Border.Effect>

                <Border CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="HÓA ĐƠN BẠN VỪA LẬP HÔM NAY" 
                                   Foreground="#34495E" FontWeight="Bold" FontSize="16" Margin="20,20,20,15"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding HoaDonCuaToi}" AutoGenerateColumns="False" IsReadOnly="True" 
                                  Background="White" RowBackground="White" AlternatingRowBackground="#F8F9FA" 
                                  RowHeight="45" HeadersVisibility="Column" BorderThickness="0" 
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAECEE">

                            <DataGrid.Resources>
                                <Style x:Key="CenterText" TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>

                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                            </DataGrid.Resources>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#34495E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Height" Value="45"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã Hóa Đơn" Binding="{Binding MaHD}" Width="200" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Thời Gian Lập" Binding="{Binding ThoiGian}" Width="200" ElementStyle="{StaticResource CenterText}"/>

                                <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CenterText}">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#27AE60"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>