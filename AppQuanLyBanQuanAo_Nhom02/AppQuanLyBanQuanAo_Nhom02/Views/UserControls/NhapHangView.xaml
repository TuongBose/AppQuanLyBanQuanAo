<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.NhapHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <!-- Thu hẹp khu vực danh sách bên trái -->
            <ColumnDefinition Width="4.5*"/>
            <!-- Mở rộng khu vực chi tiết phiếu nhập bên phải -->
            <ColumnDefinition Width="5.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="15,15,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍 Tra cứu:" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Grid.Column="1" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="5" Background="White">
                        <Grid>
                            <TextBlock Text="Nhập tên nhà cung cấp để tìm..." Foreground="#95A5A6" FontSize="14" FontStyle="Italic" VerticalAlignment="Center" Padding="14,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearchPN}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="txtSearchPN" Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="14" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PhieuNhapView}" SelectedItem="{Binding PhieuNhapDangChon}"
                          AutoGenerateColumns="False" IsReadOnly="True" RowHeight="40"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" 
                          Background="White" BorderBrush="#BDC3C7"
                          RowBackground="White" AlternatingRowBackground="#F8F9FA" 
                          SelectionUnit="FullRow" SelectionMode="Single" Cursor="Hand">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                    </DataGrid.Resources>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <!-- Dán đè đoạn này vào DataGrid.ColumnHeaderStyle của TẤT CẢ các form -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#34495E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <!-- GIỮ LẠI DÒNG NÀY ĐỂ TIÊU ĐỀ ĐẸP -->
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50" ElementStyle="{StaticResource CenterAlignStyle}"/>

                        <DataGridTextColumn Header="Mã phiếu nhập" Binding="{Binding MaPN, StringFormat=PN{0:D3}}" Width="120" ElementStyle="{StaticResource CenterAlignStyle}"/>

                        <DataGridTextColumn Header="Nhà cung cấp" Binding="{Binding NhaCungCap}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <!-- Căn giữa tuyệt đối -->
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhap}" Width="110" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat={}{0:N0}}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#D35400"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PHIẾU NHẬP HÀNG" FontWeight="ExtraBold" FontSize="24" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="1">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Nhà cung cấp *" FontWeight="SemiBold" FontSize="13" Foreground="#34495E" Margin="0,0,0,5"/>
                        <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#F8F9FA">
                            <TextBox Text="{Binding PhieuNhapMoi.NhaCungCap, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Padding="10,8" FontSize="14" Background="Transparent" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3.5*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="6.5*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ngày nhập" FontWeight="SemiBold" FontSize="13" Foreground="#34495E" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#ECF0F1">
                                <TextBox Text="{Binding PhieuNhapMoi.NgayNhap}" IsReadOnly="True" Padding="10,8" FontSize="14" Background="Transparent" BorderThickness="0" Foreground="#7F8C8D" TextChanged="TextBox_TextChanged"/>
                            </Border>
                        </StackPanel>
                        <!-- Khu vực Tìm & Chọn sản phẩm tích hợp -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tìm &amp; Chọn sản phẩm *" FontWeight="SemiBold" FontSize="13" Foreground="#34495E" Margin="0,0,0,5"/>

                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#F8F9FA">
                                <StackPanel>
                                    <!-- 1. Thanh tìm kiếm nhỏ ở trên -->
                                    <Grid Background="White">
                                        <TextBlock Text="🔍 Nhập màu, size để lọc..." Foreground="#95A5A6" FontSize="12" FontStyle="Italic" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text.Length, ElementName=txtTimSP}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox x:Name="txtTimSP" Text="{Binding TimKiemSanPham, UpdateSourceTrigger=PropertyChanged}" 
                                                 Padding="10,6" FontSize="12" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#ECF0F1" Foreground="#2C3E50"/>
                                    </Grid>

                                    <!-- 2. ComboBox hiển thị danh sách đã bị lọc ở dưới -->
                                    <ComboBox ItemsSource="{Binding SanPhamView}" 
                                              SelectedValue="{Binding ChiTietMoi.MaSP, Mode=TwoWay}" 
                                              DisplayMemberPath="TenHienThi" SelectedValuePath="MaSP" 
                                              Padding="10,8" FontSize="14" Background="Transparent" BorderThickness="0"
                                              ToolTip="Bấm vào để chọn sản phẩm sau khi đã lọc"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Số lượng nhập *" FontWeight="SemiBold" FontSize="13" Foreground="#34495E" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#F8F9FA">
                                <!-- ĐÃ BỔ SUNG CÁC LỆNH CHẶN KÝ TỰ VÀ TẮT BỘ GÕ -->
                                <TextBox Text="{Binding ChiTietMoi.SoLuongNhap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         PreviewTextInput="NumberValidationTextBox"
                                         PreviewKeyDown="SpaceValidationTextBox"
                                         DataObject.Pasting="TextBox_Pasting"
                                         InputMethod.IsInputMethodEnabled="False"
                                         Padding="10,8" FontSize="14" Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giá nhập (VNĐ) *" FontWeight="SemiBold" FontSize="13" Foreground="#34495E" Margin="0,0,0,5"/>
                            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#F8F9FA">
                                <!-- ĐÃ BỔ SUNG CÁC LỆNH CHẶN KÝ TỰ VÀ TẮT BỘ GÕ -->
                                <TextBox Text="{Binding ChiTietMoi.GiaNhap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         PreviewTextInput="NumberValidationTextBox"
                                         PreviewKeyDown="SpaceValidationTextBox"
                                         DataObject.Pasting="TextBox_Pasting"
                                         InputMethod.IsInputMethodEnabled="False"
                                         Padding="10,8" FontSize="14" Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding ThemChiTietCommand}" Height="40" Background="{Binding MauNutThemChiTiet, FallbackValue='#3498DB'}" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IconNutThemChiTiet, FallbackValue='➕'}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TextNutThemChiTiet, FallbackValue='Thêm vào danh sách nhập'}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Command="{Binding HuySuaChiTietCommand}" Height="40" Padding="15,0" Background="#95A5A6" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand" BorderThickness="0"
                                Visibility="{Binding IsEditChiTietMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Hủy" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>

                <DockPanel Grid.Row="2" Margin="0,0,0,15">

                    <TextBlock DockPanel.Dock="Top" Text="CHI TIẾT PHIẾU NHẬP HÀNG" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,5,0,8" HorizontalAlignment="Left"/>

                    <DataGrid ItemsSource="{Binding ChiTietPhieuNhap}" SelectedItem="{Binding ChiTietDangChon}"
                              AutoGenerateColumns="False" HeadersVisibility="Column" RowHeight="40"
                              Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" CanUserAddRows="False" SelectionMode="Single" SelectionUnit="FullRow">

                        <!-- THÊM ĐOẠN NÀY VÀO ĐỂ TẮT VIỀN ĐEN KHI CHỌN Ô -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <!-- Cột STT -->
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="45" ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>

                            <!-- Cột Tên Sản Phẩm (Đã thêm IsReadOnly="True" để KHÔNG cho sửa) -->
                            <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSP}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Cột Màu Sắc (Thêm mới) -->
                            <DataGridTextColumn Header="Màu sắc" Binding="{Binding MauSac}" Width="80" ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>

                            <!-- Cột Size (Thêm mới) -->
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>

                            <!-- Cột Số lượng & Giá nhập -->
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuongNhap}" Width="85" ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Giá nhập" Binding="{Binding GiaNhap, StringFormat={}{0:N0}}" Width="110" ElementStyle="{StaticResource CenterAlignStyle}" IsReadOnly="True"/>

                            <!-- Nút Xóa -->
                            <DataGridTemplateColumn Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️" ToolTip="Xóa khỏi danh sách" Command="{Binding DataContext.XoaChiTietCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Background="Transparent" BorderThickness="0" FontSize="15" Cursor="Hand" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="6" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>

                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="TỔNG TIỀN:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" FontSize="26" Foreground="#E74C3C" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1.8*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="🔄 Làm mới" Command="{Binding LamMoiCommand}" 
                                    Height="50" FontSize="14" FontWeight="Bold" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Column="2" Content="✎ CẬP NHẬT" Command="{Binding CapNhatPhieuNhapCommand}" 
                                    Height="50" FontSize="14" FontWeight="Bold" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Column="4" Content="💾 NHẬP KHO" Command="{Binding LuuPhieuNhapCommand}" 
                                    Height="50" FontSize="16" FontWeight="ExtraBold" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#BDC3C7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>