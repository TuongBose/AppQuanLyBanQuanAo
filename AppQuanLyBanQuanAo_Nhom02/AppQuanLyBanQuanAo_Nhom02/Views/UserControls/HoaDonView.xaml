<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.HoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="15,15,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔍 Tìm kiếm:" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Border Grid.Column="1" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="5" Background="White">
                        <Grid>
                            <TextBlock Text="Nhập mã hoặc tên sản phẩm để tìm..." Foreground="#95A5A6" FontSize="14" FontStyle="Italic" VerticalAlignment="Center" Padding="14,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearchSP}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="txtSearchSP" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="14" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding DanhSachSanPham}" SelectedItem="{Binding SanPhamDuocChon}"
                          AutoGenerateColumns="False" IsReadOnly="True" RowHeight="40"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" Background="White"
                          BorderBrush="#BDC3C7" BorderThickness="1" RowBackground="White" AlternatingRowBackground="#F8F9FA"
                          SelectionUnit="FullRow" SelectionMode="Single" Cursor="Hand">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#34495E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSP}" Width="2*" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Màu sắc" Binding="{Binding MauSac}" Width="*" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding GiaBan, StringFormat={}{0:N0}}" Width="1.2*" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Tồn" Binding="{Binding SoLuongTon}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="HÓA ĐƠN" FontWeight="ExtraBold" FontSize="24" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderThickness="2" CornerRadius="4" Background="#F8F9FA">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#BDC3C7"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#2ECC71"/>
                                            <Setter Property="Background" Value="#EBF5FB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <TextBlock Text="Nhập SĐT để tìm..." Foreground="#95A5A6" FontSize="14" FontStyle="Italic" VerticalAlignment="Center" Padding="14,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=txtSearchKH}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="txtSearchKH" Text="{Binding SearchKhachHangKeyword, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Background="Transparent" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding TimKhachHangCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Grid>
                        </Border>

                        <Button Grid.Column="1" Content="🔍 Tìm SĐT" Command="{Binding TimKhachHangCommand}" Background="#3498DB" Foreground="White" FontWeight="Bold" Padding="15,0" Margin="10,0,0,0" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Border Margin="0,10,0,0" Background="#E8F8F5" BorderBrush="#2ECC71" BorderThickness="1" CornerRadius="6" Padding="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KhachHangHienTai}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✔️" FontSize="20" Foreground="#27AE60" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding KhachHangHienTai.TenKH}" FontWeight="Bold" Foreground="#27AE60" FontSize="15"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="SĐT: " Foreground="#7F8C8D" FontSize="13"/>
                                    <TextBlock Text="{Binding KhachHangHienTai.SDT}" Foreground="#2C3E50" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="  |  Điểm: " Foreground="#7F8C8D" FontSize="13" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding KhachHangHienTai.DiemTichLuy}" Foreground="#D35400" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding GioHang}" AutoGenerateColumns="False" HeadersVisibility="Column" 
                          RowHeight="45" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" CanUserAddRows="False" SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mặt hàng" Binding="{Binding TenSP}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Số lượng" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="-" Command="{Binding DataContext.GiamSoLuongCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Width="24" Height="24" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        
                                        <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" 
                                                 Width="35" TextAlignment="Center" VerticalContentAlignment="Center" 
                                                 FontWeight="Bold" FontSize="14" BorderBrush="#BDC3C7" BorderThickness="1" Margin="3,0"
                                                 PreviewTextInput="NumberValidationTextBox"
                                                 LostFocus="txtSoLuong_LostFocus">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return" Command="{Binding DataContext.CapNhatSoLuongNhapCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        
                                        <Button Content="+" Command="{Binding DataContext.TangSoLuongCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Width="24" Height="24" Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="95" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#D35400"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" ToolTip="Xóa món này" Command="{Binding DataContext.XoaMonCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" FontSize="14" Cursor="Hand" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="6" Padding="15" Margin="0,15,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="TỔNG TIỀN:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" FontSize="26" Foreground="#E74C3C" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="2.5*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="🔄 Làm mới" Command="{Binding LamMoiCommand}" 
                                    Height="55" FontSize="16" FontWeight="Bold" 
                                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <Button Grid.Column="2" Content="💰 THANH TOÁN" Command="{Binding ThanhToanCommand}" 
                                    Height="55" FontSize="20" FontWeight="Bold" 
                                    Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#BDC3C7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>