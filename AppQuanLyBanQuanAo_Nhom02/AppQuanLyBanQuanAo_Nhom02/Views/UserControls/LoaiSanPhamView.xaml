<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.LoaiSanPhamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="Transparent">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="6.5*"/>
        </Grid.ColumnDefinitions>

        <!-- CỘT TRÁI: THÔNG TIN LOẠI SẢN PHẨM -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="THÔNG TIN LOẠI SẢN PHẨM" FontWeight="ExtraBold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <TextBlock Text="Mã Loại (Tự động):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="#ECF0F1" Margin="0,0,0,15">
                        <TextBox Text="{Binding CurrentLoai.MaLoai}" IsReadOnly="True" Background="Transparent" Padding="10,8" BorderThickness="0" FontSize="14" Foreground="#7F8C8D" VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Tên Loại Sản Phẩm (*):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,25">
                        <Grid>
                            <TextBlock Text="Nhập tên loại sản phẩm..." 
                                       Foreground="#95A5A6" FontSize="14" FontStyle="Italic"
                                       VerticalAlignment="Center" Padding="12,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=txtTenLoai}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBox x:Name="txtTenLoai"
                                     Text="{Binding CurrentLoai.TenLoai, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10,8" BorderThickness="0" FontSize="14"
                                     Background="Transparent" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="2" Rows="2">

                    <Button Command="{Binding AddCommand}" 
                            IsEnabled="{Binding IsAdmin}"
                            Background="#27AE60" Foreground="White" Padding="10" Margin="5" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm Mới" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding UpdateCommand}" 
                            IsEnabled="{Binding IsAdmin}"
                            Background="#F39C12" Foreground="White" Padding="10" Margin="5" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✎" FontSize="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cập Nhật" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteCommand}" CommandParameter="{Binding ElementName=dgLoaiSanPham, Path=SelectedItems}" 
                            IsEnabled="{Binding IsAdmin}"
                            Background="#E74C3C" Foreground="White" Padding="10" Margin="5" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🗑" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xóa" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}" Background="#95A5A6" Foreground="White" Padding="10" Margin="5" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Làm Mới" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </UniformGrid>
            </Grid>
        </Border>

        <!-- CỘT PHẢI: TÌM KIẾM VÀ DANH SÁCH -->
        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Thanh tìm kiếm mỏng, màu viền xanh đồng bộ -->
                <Grid Grid.Row="0" Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔍 Tìm kiếm loại sản phẩm:" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="14"/>

                    <Border Grid.Column="1" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="5" Background="White">
                        <Grid>
                            <TextBlock Text="Nhập tên loại sản phẩm để tìm..." 
                                       Foreground="#95A5A6" FontStyle="Italic" FontSize="14" 
                                       Padding="12,8" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBox x:Name="SearchBox" 
                                     Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="10,8" BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bảng DataGrid -->
                <DataGrid Grid.Row="1" x:Name="dgLoaiSanPham" ItemsSource="{Binding DanhSachLoai}" 
                          SelectedItem="{Binding CurrentLoai}" 
                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                          Background="White" RowHeight="40" FontSize="14" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" 
                          RowBackground="White" AlternatingRowBackground="#F8F9FA"
                          SelectionUnit="FullRow" SelectionMode="Extended" Cursor="Hand">

                    <!-- Định dạng tiêu đề cột xanh đen -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#34495E"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Resources>
                        <Style x:Key="CenterText" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                    </DataGrid.Resources>

                    <!-- Xóa viền đen của ô khi click -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60" ElementStyle="{StaticResource CenterText}"/>
                        <DataGridTextColumn Header="Mã loại" Binding="{Binding MaHienThi}" Width="150" ElementStyle="{StaticResource CenterText}"/>
                        <DataGridTextColumn Header="Tên loại sản phẩm" Binding="{Binding TenLoai}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <!-- Thêm lệnh căn giữa -->
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Số lượng mẫu mã" Binding="{Binding SoLuongSanPham}" Width="180" ElementStyle="{StaticResource CenterText}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>