<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.BaoCaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding HomNayCommand}" Content="Hôm nay" Padding="15,8" Margin="0,0,8,0" Background="#ECF0F1" Foreground="#2C3E50" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Command="{Binding TuanNayCommand}" Content="Tuần này" Padding="15,8" Margin="0,0,8,0" Background="#ECF0F1" Foreground="#2C3E50" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Command="{Binding ThangNayCommand}" Content="Tháng này" Padding="15,8" Background="#ECF0F1" Foreground="#2C3E50" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20,10" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Từ:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="#34495E"/>
                    <DatePicker SelectedDate="{Binding TuNgay}" Width="110" BorderBrush="#BDC3C7" VerticalAlignment="Center"/>

                    <TextBlock Text="Đến:" VerticalAlignment="Center" Margin="20,0,8,0" FontWeight="SemiBold" Foreground="#34495E"/>
                    <DatePicker SelectedDate="{Binding DenNgay}" Width="110" BorderBrush="#BDC3C7" VerticalAlignment="Center"/>

                    <Button Command="{Binding ThongKeCommand}" Content="🔍 Lọc" Padding="20,8" Margin="15,0,0,0" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="8" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <Button Command="{Binding ExportExcelCommand}" Content="📥 Xuất Excel" Padding="20,8" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#E8F8F5" CornerRadius="8" Padding="20" BorderBrush="#2ECC71" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💰 TỔNG DOANH THU" Foreground="#27AE60" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} VNĐ}" Foreground="#2C3E50" FontWeight="ExtraBold" FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#EBF5FB" CornerRadius="8" Padding="20" BorderBrush="#3498DB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📄 SỐ LƯỢNG HÓA ĐƠN" Foreground="#2980B9" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TongHoaDon, StringFormat={}{0} đơn}" Foreground="#2C3E50" FontWeight="ExtraBold" FontSize="26"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="#FEF9E7" CornerRadius="8" Padding="20" BorderBrush="#F1C40F" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⭐ KHÁCH MUA NHIỀU NHẤT" Foreground="#D4AC0D" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding KhachHangTop}" Foreground="#2C3E50" FontWeight="ExtraBold" FontSize="20" VerticalAlignment="Bottom" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.8*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="5.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH HÓA ĐƠN" FontSize="16" FontWeight="ExtraBold" Foreground="#34495E" Margin="0,10,0,10" HorizontalAlignment="Center"/>
                    <DataGrid ItemsSource="{Binding DanhSachHoaDon}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="40"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" 
                              Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                              RowBackground="White" AlternatingRowBackground="#F8F9FA" SelectionUnit="FullRow" SelectionMode="Single">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        </DataGrid.Resources>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="45" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHD, StringFormat=HD{0:D3}}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH, StringFormat=KH{0:D3}}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>
                            <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLap}" Width="120" ElementStyle="{StaticResource CenterAlignStyle}"/>

                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#D35400"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Thao tác" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="👁️ Chi tiết" 
                                                Command="{Binding DataContext.XemChiTietCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2"
                                                Padding="8,4" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="BIỂU ĐỒ TRỰC QUAN" FontSize="16" FontWeight="ExtraBold" Foreground="#34495E" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding ColumnSeries}" XAxes="{Binding XAxes}" Margin="0,0,0,10"/>
                    <lvc:PieChart Grid.Row="2" Series="{Binding PieSeries}" Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>