<UserControl x:Class="AppQuanLyBanQuanAo_Nhom02.Views.UserControls.SaoLuuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppQuanLyBanQuanAo_Nhom02.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📁 Thư mục lưu trữ:" FontWeight="SemiBold" FontSize="14" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Background="#F8F9FA" Width="450" Margin="0,0,10,0">
                    <TextBox Text="{Binding DuongDanBackup, Mode=OneWay}" IsReadOnly="True" Padding="10,8" FontSize="13" Background="Transparent" BorderThickness="0" Foreground="#7F8C8D" VerticalContentAlignment="Center"/>
                </Border>

                <Button Command="{Binding ChonThuMucCommand}" Content="📂 Thay đổi" Padding="20,8" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6.5*"/>
                <ColumnDefinition Width="3.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,15,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH CÁC BẢN SAO LƯU DỮ LIỆU" FontSize="16" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#34495E" Margin="0,10,0,15"/>
                    <DataGrid x:Name="dgBackup" ItemsSource="{Binding DanhSachBackup}" SelectedItem="{Binding BackupDangChon}"
                              AutoGenerateColumns="False" IsReadOnly="True" RowHeight="40"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1" 
                              Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                              RowBackground="White" AlternatingRowBackground="#F8F9FA" 
                              SelectionUnit="FullRow" SelectionMode="Extended" Cursor="Hand">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3498DB"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                        </DataGrid.Resources>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60" ElementStyle="{StaticResource CenterAlignStyle}"/>

                            <DataGridTextColumn Header="Tên bản sao lưu (File Name)" Binding="{Binding FileName}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Thời gian tạo" Binding="{Binding CreatedDate, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="180" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,171">
                <StackPanel>
                    <TextBlock Text="ℹ️ THÔNG TIN TỔNG QUAN" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,15"/>

                    <Border Background="#E8F8F5" BorderBrush="#2ECC71" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,40">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Số lượng file:" Width="120" Foreground="#2C3E50" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DanhSachBackup.Count, StringFormat='{}{0} file backup'}" FontWeight="Bold" Foreground="#27AE60" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Tổng dung lượng:" Width="120" Foreground="#2C3E50" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DungLuongFormatted}" FontWeight="Bold" Foreground="#D35400" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="Lần lưu gần nhất:" Width="120" Foreground="#2C3E50" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ThoiGianCuoiSaoLuuFormatted}" FontWeight="Bold" Foreground="#2980B9" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="⚙️ ĐIỀU KHIỂN HỆ THỐNG" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#34495E" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding SaoLuuNgayCommand}"
                                Content="💾 SAO LƯU NGAY" Height="50" FontSize="15" FontWeight="Bold" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Command="{Binding LamMoiCommand}" Content="🔄 LÀM MỚI" Height="50" Padding="15,0" FontSize="13" FontWeight="Bold" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Tải lại danh sách">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <Button Command="{Binding PhucHoiCommand}"
                            CommandParameter="{Binding ElementName=dgBackup, Path=SelectedItems}"
                            Content="♻️ PHỤC HỒI TỪ FILE ĐÃ CHỌN" Height="50" FontSize="15" FontWeight="Bold" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDC3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding XoaBackupCommand}"
                            CommandParameter="{Binding ElementName=dgBackup, Path=SelectedItems}"
                            Content="✕ XÓA FILE ĐÃ CHỌN" Height="50" FontSize="15" FontWeight="Bold" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDC3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>